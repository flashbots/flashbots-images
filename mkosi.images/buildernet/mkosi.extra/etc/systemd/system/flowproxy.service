[Unit]
Description=FlowProxy - order flow proxy for BuilderNet
Wants=network-online.target
After=network.target network-online.target flowproxy-downloader.service
Requires=flowproxy-downloader.service

[Service]
Type=exec
DynamicUser=yes
StateDirectory=persistent/flowproxy
EnvironmentFile=%E/flowproxy/flowproxy.env
LoadCredential=api-keys.toml:%E/flowproxy/api-keys.toml
LoadCredential=filter-rules.toml:%E/flowproxy/filter-rules.toml
Environment=API_KEYS_FILE=%d/api-keys.toml
Environment=ORDERFLOW_FILTER_RULES_FILE=%d/filter-rules.toml
ExecStart=/usr/bin/flowproxy
LimitNOFILE=65535
Restart=on-failure
RestartSec=5s
RestartSteps=5
RestartMaxDelaySec=1min

[Install]
WantedBy=multi-user.target
