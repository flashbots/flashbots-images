[Unit]
Description=FlowProxy - order flow proxy for BuilderNet
Wants=network-online.target
After=network.target network-online.target

[Service]
Type=exec
DynamicUser=yes
ConfigurationDirectory=flowproxy
StateDirectory=persistent/flowproxy
EnvironmentFile=%E/flowproxy/flowproxy.env
ExecStart=/usr/bin/flowproxy
LimitNOFILE=65535
Restart=on-failure
RestartSec=5s
RestartSteps=5
RestartMaxDelaySec=1min

[Install]
WantedBy=multi-user.target
