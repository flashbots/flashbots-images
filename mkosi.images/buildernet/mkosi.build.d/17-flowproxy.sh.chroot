#!/usr/bin/env bash
set -euo pipefail

echo "Installing flowproxy..."

# https://github.com/BuilderNet/FlowProxy/releases
VERSION=v2.1.3
EXPECTED_SHA256=36f4a4c4e413d7943b4666ce3d4e4169e2fa3e128d42f528af695a88bdca1505

mkdir -p $DESTDIR/usr/bin
curl -fSsL -o $DESTDIR/usr/bin/flowproxy https://github.com/BuilderNet/FlowProxy/releases/download/${VERSION}/flowproxy
echo "${EXPECTED_SHA256}" $DESTDIR/usr/bin/flowproxy | sha256sum --check
chmod +x $DESTDIR/usr/bin/flowproxy
