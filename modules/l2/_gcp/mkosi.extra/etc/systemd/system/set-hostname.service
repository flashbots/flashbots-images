[Unit]
Description=Set hostname
ConditionFirstBoot=yes
After=network.target network-setup.service
Wants=network-setup.service

StartLimitIntervalSec=0
StartLimitBurst=0

[Service]
User=root
Group=root
Type=oneshot
ExecStart=/usr/bin/set-hostname-gcp.sh

Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
