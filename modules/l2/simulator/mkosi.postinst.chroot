#!/bin/bash

set -euxo pipefail

# Enable systemd services

for service in \
    node-healthchecker.service
do
    systemctl enable "$service"
    systemctl add-wants minimal.target "$service"
done

# Create users and groups
groupadd -g 2000    optimism                           || true
useradd  -u 2003 -g optimism -m -s /bin/bash simulator || true
