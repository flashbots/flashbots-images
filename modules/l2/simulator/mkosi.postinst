#!/bin/bash

set -euxo pipefail

# Enable systemd services

mkosi-chroot systemctl add-wants minimal.target \
    node-healthchecker.service

# Create users and groups
mkosi-chroot groupadd -g 2000    optimism                           || true
mkosi-chroot useradd  -u 2003 -g optimism -m -s /bin/bash simulator || true
