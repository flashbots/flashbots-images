
# Remote write configuration (rendered at boot from Vault-provided values).
remote_write:
  # AWS Managed Prometheus, reached via the internal TCP-proxy load balancer.
  # Host is the fixed LB IP (10.88.0.100, see terraform amp-proxy.tf), so no
  # DNS resolution happens on the VM. TLS SNI + cert validation are overridden
  # to AMP's real regional hostname via tls_config.server_name
  # (aps-workspaces.<region>.amazonaws.com is AMP's standard regional endpoint).
  - url: https://10.88.0.100/workspaces/${METRICS_FLASHBOTS_WORKSPACE}/api/v1/remote_write
    write_relabel_configs:
      # Only send flashbox: prefixed metrics
      - source_labels: [__name__]
        regex: 'flashbox:.*'
        action: keep
    tls_config:
      server_name: aps-workspaces.${METRICS_FLASHBOTS_REGION}.amazonaws.com
    sigv4:
      region: ${METRICS_FLASHBOTS_REGION}
      access_key: ${METRICS_FLASHBOTS_ACCESS_KEY}
      secret_key: ${METRICS_FLASHBOTS_SECRET_KEY}
