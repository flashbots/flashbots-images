{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Container Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Container Alive",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus-remote-write" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "#ef4444", "value": null }, { "color": "#10b981", "value": 1 }] },
          "mappings": [{ "type": "range", "options": { "from": 1, "to": 9999, "result": { "text": "UP", "color": "#10b981" } } }, { "type": "value", "options": { "0": { "text": "DOWN", "color": "#ef4444" } } }]
        },
        "overrides": []
      },
      "targets": [
        { "expr": "clamp_max(flashbox:container_alive, 1)", "legendFormat": "Container", "refId": "A", "instant": true }
      ]
    },
    {
      "title": "CPU",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus-remote-write" },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 4, "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#10b981", "value": null },
            { "color": "#fbbf24", "value": 1.01 },
            { "color": "#f97316", "value": 2.01 },
            { "color": "#ef4444", "value": 3.01 }
          ]},
          "mappings": [
            { "type": "value", "options": {
              "1": { "text": "LOW", "index": 0 },
              "2": { "text": "MED", "index": 1 },
              "3": { "text": "HIGH", "index": 2 },
              "4": { "text": "CRIT", "index": 3 }
            }}
          ]
        },
        "overrides": []
      },
      "targets": [
        { "expr": "flashbox:container_cpu_level", "refId": "A", "instant": true }
      ]
    },
    {
      "title": "Memory",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus-remote-write" },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 4, "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#10b981", "value": null },
            { "color": "#fbbf24", "value": 1.01 },
            { "color": "#f97316", "value": 2.01 },
            { "color": "#ef4444", "value": 3.01 }
          ]},
          "mappings": [
            { "type": "value", "options": {
              "1": { "text": "LOW", "index": 0 },
              "2": { "text": "MED", "index": 1 },
              "3": { "text": "HIGH", "index": 2 },
              "4": { "text": "CRIT", "index": 3 }
            }}
          ]
        },
        "overrides": []
      },
      "targets": [
        { "expr": "flashbox:container_memory_level", "refId": "A", "instant": true }
      ]
    },
    {
      "title": "Bucket Thresholds",
      "type": "text",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "options": {
        "mode": "markdown",
        "content": "**CPU** 🟢 0-20 🟡 20-40 🟠 40-85 🔴 85+\n\n**Mem** 🟢 0-30 🟡 30-70 🟠 70-90 🔴 90+\n\n*15m avg window*"
      }
    },
    {
      "title": "Host Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "title": "CPU",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-remote-write" },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 4, "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#10b981", "value": null },
            { "color": "#fbbf24", "value": 1.01 },
            { "color": "#f97316", "value": 2.01 },
            { "color": "#ef4444", "value": 3.01 }
          ]},
          "mappings": [
            { "type": "value", "options": {
              "1": { "text": "LOW", "index": 0 },
              "2": { "text": "MED", "index": 1 },
              "3": { "text": "HIGH", "index": 2 },
              "4": { "text": "CRIT", "index": 3 }
            }}
          ]
        },
        "overrides": []
      },
      "targets": [
        { "expr": "flashbox:cpu_level", "refId": "A", "instant": true }
      ]
    },
    {
      "title": "Memory",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-remote-write" },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 4, "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#10b981", "value": null },
            { "color": "#fbbf24", "value": 1.01 },
            { "color": "#f97316", "value": 2.01 },
            { "color": "#ef4444", "value": 3.01 }
          ]},
          "mappings": [
            { "type": "value", "options": {
              "1": { "text": "LOW", "index": 0 },
              "2": { "text": "MED", "index": 1 },
              "3": { "text": "HIGH", "index": 2 },
              "4": { "text": "CRIT", "index": 3 }
            }}
          ]
        },
        "overrides": []
      },
      "targets": [
        { "expr": "flashbox:memory_level", "refId": "A", "instant": true }
      ]
    },
    {
      "title": "Disk (root)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-remote-write" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "#10b981", "value": null }, { "color": "#fbbf24", "value": 70 }, { "color": "#ef4444", "value": 90 }] } },
        "overrides": []
      },
      "targets": [
        { "expr": "flashbox:disk_usage_percent_root", "refId": "A" }
      ]
    },
    {
      "title": "Disk (persistent)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-remote-write" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "#10b981", "value": null }, { "color": "#fbbf24", "value": 70 }, { "color": "#ef4444", "value": 90 }] } },
        "overrides": []
      },
      "targets": [
        { "expr": "flashbox:disk_usage_percent_persistent", "refId": "A" }
      ]
    },
    {
      "title": "Disk I/O (MB/s)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus-remote-write" },
      "fieldConfig": {
        "defaults": { "unit": "MBs", "color": { "mode": "fixed" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Read" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10b981" } }] },
          { "matcher": { "id": "byName", "options": "Write" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#f97316" } }] }
        ]
      },
      "targets": [
        { "expr": "flashbox:disk_io_read_mb_per_sec", "legendFormat": "Read", "refId": "A" },
        { "expr": "flashbox:disk_io_write_mb_per_sec", "legendFormat": "Write", "refId": "B" }
      ],
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "title": "Network Traffic (MB/s)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus-remote-write" },
      "fieldConfig": {
        "defaults": { "unit": "MBs", "color": { "mode": "fixed" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Received" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10b981" } }] },
          { "matcher": { "id": "byName", "options": "Transmitted" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#f97316" } }] }
        ]
      },
      "targets": [
        { "expr": "flashbox:network_receive_mb_per_sec", "legendFormat": "Received", "refId": "A" },
        { "expr": "flashbox:network_transmit_mb_per_sec", "legendFormat": "Transmitted", "refId": "B" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["flashbox", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Flashbox Overview",
  "uid": "flashbox-overview"
}
