{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Flashbox Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Container Alive",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus-remote-write" },
      "fieldConfig": {
        "defaults": {
          "noValue": "\u2753",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#ef4444", "value": null }, { "color": "#10b981", "value": 1 }] },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "\u26a0\ufe0f" }, "1": { "text": "\u2705" } } }
          ]
        },
        "overrides": []
      },
      "targets": [
        { "expr": "clamp_max(flashbox:container_alive, 1)", "refId": "A", "instant": true }
      ],
      "options": { "graphMode": "none", "textMode": "value", "justifyMode": "center" }
    },
    {
      "title": "Container CPU < 80%",
